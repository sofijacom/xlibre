# Template file for 'xf86-input-wacom'
pkgname=xlibre-xf86-input-wacom
_pkgname=xf86-input-wacom
version=1.2.3.1
revision=2
build_style=meson
hostmakedepends="pkg-config"
makedepends="xlibre-server xlibre-server-devel xlibre-server-common autoconf automake binutils fakeroot findutils gawk gcc gettext gzip libtool m4 make patch pkgconf meson gobject-introspection"
depends="libXi libXinerama libXrandr libX11 glibc"
short_desc="XLibre fork of X.Org Wacom tablet driver"
maintainer="Sofiya <sofiya@v.com>"
license="GPL-2.0-or-later"
homepage="https://github.com/X11Libre"
conflicts="xf86-input-wacom"
replaces="xf86-input-wacom"
distfiles="https://github.com/X11Libre/${_pkgname}/archive/refs/tags/${pkgname}-${version}.tar.gz"
checksum=961f7b229e79e585a85b59be395e54392c00a3766204de95af832d2fa59207ed
lib32disabled=yes

prepare() {
  cd ${DESTDIR}/${_pkgname}-${pkgname}-${version}
  patch -Np1 -i ${srcdir}/aggregate.patch
}

pre_configure() {

    --prefix=/usr \
    --libexecdir=lib \
    -D xorg-conf-dir=/usr/share/X11/xorg.conf.d/ \
    -D unittests=disabled

  meson configure build
  ninja -C build

}

post_install() {
	vlicense COPYING
}
