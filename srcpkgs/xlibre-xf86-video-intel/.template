# Template file for 'xf86-video-intel'
pkgname=xlibre-xf86-video-intel
_pkgname=xf86-video-intel
version=${VERSION}
revision=1
build_style=gnu-configure
configure_args="--with-default-dri=3"
hostmakedepends="git automake libtool pkg-config xorg-util-macros"
makedepends="xlibre-server xlibre-server-devel xlibre-server-common autoconf automake binutils fakeroot findutils gawk gcc gettext gzip libtool m4 make patch pkgconf xorg-util-macros libXScrnSaver-devel libXcursor-devel libXinerama-devel libXrandr-devel libXvMC-devel "
depends="virtual?xserver-abi-video-25_1 mesa-dri"
short_desc="XLibre fork Intel video driver"
maintainer="Sofiya <sofiya@v.com>"
license="MIT"
homepage="https://github.com/X11Libre/xf86-video-intel"
distfiles="https://github.com/X11Libre/${_pkgname}/archive/refs/tags/${pkgname}-${version}.tar.gz"
checksum=${SHA256}
lib32disabled=yes

CFLAGS="-fcommon"
LDFLAGS="-Wl,-z,lazy"

pre_configure() {
	NOCONFIGURE=1 ./autogen.sh
}

post_install() {
	vlicense COPYING
}




