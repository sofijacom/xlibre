# Template file for 'xf86-video-amdgpu'
pkgname=xlibre-xf86-video-amdgpu
_pkgname=xf86-video-amdgpu
version=${VERSION}
revision=1
build_style=gnu-configure
configure_args="--enable-places-udisks2"
hostmakedepends="pkg-config"
makedepends="xlibre-server xlibre-server-devel xlibre-server-common
autoconf automake binutils fakeroot findutils gawk gcc gettext gzip libtool m4 make patch pkgconf xorg-util-macros"
depends="virtual?xserver-abi-videodrv-23.0"
short_desc="XLibre fork of X.Org amdgpu video driver"
maintainer="Sofiya <sofiya@v.com>"
license="MIT"
homepage="https://lists.freedesktop.org/mailman/listinfo/amd-gfx"
distfiles="https://github.com/X11Libre/${_pkgname}/archive/refs/tags/${pkgname}-${version}.tar.gz"
checksum=${SHA256}
lib32disabled=yes

pre_configure() {

  ./autogen.sh
  ./configure --prefix=/usr
  make
}

post_install() {
	vlicense COPYING
}
